// ============================================================
// STATE
// ============================================================
let currentUser = null;
let terminyFilter = 'vse';
let terminySearch = '';

// ============================================================
// AUTH
// ============================================================
function quickLogin(email, pass) {
  document.getElementById('login-email').value = email;
  document.getElementById('login-password').value = pass;
}

function doLogin() {
  const email = document.getElementById('login-email').value.trim().toLowerCase();
  const pass  = document.getElementById('login-password').value;
  const acc   = ACCOUNTS[email];
  if (!acc || acc.pass !== pass) {
    document.getElementById('login-error').textContent = 'Nesprávný e-mail nebo heslo.';
    return;
  }
  document.getElementById('login-error').textContent = '';
  currentUser = { ...acc, email };
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  document.getElementById('user-name-display').textContent = acc.name;

  const isAdmin = acc.role === 'admin';
  document.getElementById('sidebar-admin-section').style.display = isAdmin ? '' : 'none';
  document.getElementById('nav-klienti').style.display          = isAdmin ? '' : 'none';

  showPage('dashboard');
}

function doLogout() {
  currentUser = null;
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-email').value = '';
  document.getElementById('login-password').value = '';
}

document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && document.getElementById('login-screen').style.display !== 'none') doLogin();
});

// ============================================================
// NAVIGATION
// ============================================================
function showPage(page) {
  ['dashboard','terminy','klienti','notifikace','export'].forEach(p => {
    document.getElementById('page-'+p).classList.toggle('hidden', p !== page);
    const nav = document.getElementById('nav-'+p);
    if (nav) nav.classList.toggle('active', p === page);
  });
  if (page === 'dashboard')  renderDashboard();
  if (page === 'terminy')    renderTerminy();
  if (page === 'klienti')    renderKlienti();
  if (page === 'notifikace') renderNotifikace();
}

// ============================================================
// HELPERS
// ============================================================
function getVisible() {
  if (!currentUser) return [];
  if (currentUser.role === 'admin') return TERMINY;
  return TERMINY.filter(t => t.clientId === currentUser.clientId);
}

function statusBadge(s) {
  if (s === 'po-splatnosti') return '<span class="badge badge-danger">⚠ Po splatnosti</span>';
  if (s === 'blizi')         return '<span class="badge badge-warn">⏰ Blíží se</span>';
  return '<span class="badge badge-ok">✓ OK</span>';
}

function daysLabel(days) {
  if (days < 0)  return `<span style="color:var(--danger);font-weight:600;">${Math.abs(days)} dní po splatnosti</span>`;
  if (days === 0) return '<span style="color:var(--danger);font-weight:600;">Dnes!</span>';
  if (days <= 30) return `<span style="color:var(--warning);font-weight:600;">${days} dní</span>`;
  return `<span style="color:var(--success);">${days} dní</span>`;
}

function kategorieBadge(k) {
  if (k === 'skoleni') return '<span class="badge badge-info">Školení</span>';
  if (k === 'revize')  return '<span class="badge badge-navy">Revize</span>';
  return '<span class="badge badge-gray">Kontrola</span>';
}

// ============================================================
// DASHBOARD
// ============================================================
function renderDashboard() {
  const data    = getVisible();
  const expired = data.filter(t => t.status === 'po-splatnosti').length;
  const soon    = data.filter(t => t.status === 'blizi').length;
  const ok      = data.filter(t => t.status === 'ok').length;

  if (currentUser.role === 'admin') {
    document.getElementById('dashboard-title').textContent    = 'Přehled — správce';
    document.getElementById('dashboard-subtitle').textContent = `Sledování BOZP/PO pro ${CLIENTS.length} klientských firem`;
  } else {
    const client = CLIENTS.find(c => c.id === currentUser.clientId);
    document.getElementById('dashboard-title').textContent    = client ? client.name : 'Moje firma';
    document.getElementById('dashboard-subtitle').textContent = 'Váš přehled BOZP a PO termínů';
  }

  // Alert banners
  let banners = '';
  if (expired > 0) banners += `<div class="notif-banner danger"><span class="notif-icon">🚨</span><div><strong>Pozor!</strong> ${expired} termín${expired > 1 ? 'y jsou' : ' je'} po datu splatnosti — vyžaduje okamžité řešení.</div></div>`;
  if (soon > 0)    banners += `<div class="notif-banner"><span class="notif-icon">⚠️</span><div><strong>Upozornění:</strong> ${soon} termín${soon > 1 ? 'y se blíží' : ' se blíží'} (do 30 dní). Naplánujte realizaci.</div></div>`;
  document.getElementById('alert-banners').innerHTML = banners;

  document.getElementById('stats-grid').innerHTML = `
    <div class="stat-card"><div class="stat-label">Celkem termínů</div><div class="stat-value">${data.length}</div><div class="stat-note">evidovaných úkonů</div></div>
    <div class="stat-card danger"><div class="stat-label">Po splatnosti</div><div class="stat-value">${expired}</div><div class="stat-note">vyžaduje řešení</div></div>
    <div class="stat-card warn"><div class="stat-label">Do 30 dní</div><div class="stat-value">${soon}</div><div class="stat-note">blíží se termín</div></div>
    <div class="stat-card ok"><div class="stat-label">V pořádku</div><div class="stat-value">${ok}</div><div class="stat-note">bez problémů</div></div>
  `;

  document.getElementById('nav-badge-terminy').textContent = expired + soon;
  document.getElementById('nav-badge-notif').textContent   = expired + soon;

  const sorted = [...data].sort((a,b) => a.days - b.days).slice(0, 8);
  document.getElementById('terminy-count').textContent = `(${sorted.length} z ${data.length})`;
  document.getElementById('terminy-tbody').innerHTML = sorted.length === 0
    ? `<tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--text-muted);">Žádné termíny k zobrazení</td></tr>`
    : sorted.map(t => `<tr>
        <td>${t.typ}</td>
        <td>${t.clientName}</td>
        <td><strong>${fmt(t.next)}</strong></td>
        <td>${daysLabel(t.days)}</td>
        <td>${statusBadge(t.status)}</td>
        <td style="color:var(--text-muted)">${t.odpovedny}</td>
      </tr>`).join('');
}

// ============================================================
// TERMÍNY PAGE
// ============================================================
function setFilter(el, val) {
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  terminyFilter = val;
  renderAllTerminy();
}

function filterTerminy() {
  terminySearch = document.getElementById('terminy-search').value.toLowerCase();
  renderAllTerminy();
}

function renderTerminy() {
  terminySearch = ''; terminyFilter = 'vse';
  document.querySelectorAll('.pill').forEach(p => p.classList.toggle('active', p.dataset.filter === 'vse'));
  document.getElementById('terminy-search').value = '';
  renderAllTerminy();
}

function renderAllTerminy() {
  let data = getVisible();
  if (terminyFilter === 'po-splatnosti') data = data.filter(t => t.status === 'po-splatnosti');
  else if (terminyFilter === 'blizi')    data = data.filter(t => t.status === 'blizi');
  else if (terminyFilter === 'ok')       data = data.filter(t => t.status === 'ok');
  else if (terminyFilter === 'skoleni')  data = data.filter(t => t.kategorie === 'skoleni');
  else if (terminyFilter === 'revize')   data = data.filter(t => t.kategorie === 'revize');
  else if (terminyFilter === 'kontrola') data = data.filter(t => t.kategorie === 'kontrola');
  if (terminySearch) data = data.filter(t =>
    t.typ.toLowerCase().includes(terminySearch) ||
    t.clientName.toLowerCase().includes(terminySearch) ||
    t.odpovedny.toLowerCase().includes(terminySearch)
  );
  data.sort((a,b) => a.days - b.days);
  document.getElementById('all-terminy-tbody').innerHTML = data.length === 0
    ? `<tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--text-muted);">Žádné záznamy neodpovídají filtru</td></tr>`
    : data.map(t => `<tr>
        <td><strong>${t.typ}</strong></td>
        <td>${kategorieBadge(t.kategorie)}</td>
        <td>${t.clientName}</td>
        <td style="color:var(--text-muted)">${fmt(t.posledni)}</td>
        <td><strong>${fmt(t.next)}</strong></td>
        <td>${daysLabel(t.days)}</td>
        <td>${statusBadge(t.status)}</td>
        <td style="color:var(--text-muted)">${t.perioda} měs.</td>
      </tr>`).join('');
}

// ============================================================
// KLIENTI PAGE
// ============================================================
function filterKlienti() {
  renderKlientiGrid(document.getElementById('klienti-search').value.toLowerCase());
}
function renderKlienti() { renderKlientiGrid(''); }
function renderKlientiGrid(q) {
  const data = CLIENTS.filter(c => !q ||
    c.name.toLowerCase().includes(q) ||
    c.ico.toLowerCase().includes(q) ||
    c.obor.toLowerCase().includes(q)
  );
  document.getElementById('clients-grid').innerHTML = data.length === 0
    ? `<div class="empty-state"><div class="empty-icon">🔍</div><div class="empty-text">Žádná firma nenalezena</div></div>`
    : data.map(c => {
        const ct  = TERMINY.filter(t => t.clientId === c.id);
        const exp = ct.filter(t => t.status === 'po-splatnosti').length;
        const bl  = ct.filter(t => t.status === 'blizi').length;
        const dot = exp > 0 ? 'dot-danger' : bl > 0 ? 'dot-warn' : 'dot-ok';
        return `<div class="client-card" onclick="openClientModal('${c.id}')">
          <div class="client-alert-dot ${dot}"></div>
          <div class="client-name">${c.name}</div>
          <div class="client-ico">${c.ico} &nbsp;·&nbsp; ${c.obor}</div>
          <div class="client-meta">
            <span class="badge ${exp > 0 ? 'badge-danger' : 'badge-ok'}">${exp > 0 ? exp+' po splatnosti' : 'Bez problémů'}</span>
            ${bl > 0 ? `<span class="badge badge-warn">${bl} blíží se</span>` : ''}
            <span class="badge badge-gray">${ct.length} úkonů</span>
          </div>
        </div>`;
      }).join('');
}

// ============================================================
// CLIENT MODAL
// ============================================================
function openClientModal(clientId) {
  const client = CLIENTS.find(c => c.id === clientId);
  if (!client) return;
  const ct = TERMINY.filter(t => t.clientId === clientId).sort((a,b) => a.days - b.days);
  document.getElementById('client-modal-content').innerHTML = `
    <div class="modal-header">
      <div>
        <div class="modal-title">${client.name}</div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:3px;">${client.ico} &nbsp;·&nbsp; ${client.obor}</div>
      </div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-section">
      <div class="modal-section-title">Kontaktní osoba</div>
      <div style="font-size:13px;line-height:1.8;color:var(--text-muted);">
        <strong style="color:var(--text);">${client.kontakt}</strong><br>
        ${client.email}<br>${client.telefon}
      </div>
    </div>
    <div class="modal-section">
      <div class="modal-section-title">Termíny BOZP / PO (${ct.length})</div>
      <div class="table-wrap" style="margin-bottom:0;">
        <table><thead><tr><th>Úkon</th><th>Typ</th><th>Termín</th><th>Zbývá</th><th>Status</th></tr></thead>
        <tbody>${ct.map(t => `<tr>
          <td><strong>${t.typ}</strong></td>
          <td>${kategorieBadge(t.kategorie)}</td>
          <td>${fmt(t.next)}</td>
          <td>${daysLabel(t.days)}</td>
          <td>${statusBadge(t.status)}</td>
        </tr>`).join('')}</tbody></table>
      </div>
    </div>`;
  document.getElementById('client-modal').classList.add('open');
}
function closeModal() { document.getElementById('client-modal').classList.remove('open'); }
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

// ============================================================
// NOTIFIKACE PAGE
// ============================================================
function renderNotifikace() {
  const data   = getVisible();
  const alerts = [];
  data.forEach(t => {
    if (t.status === 'po-splatnosti')
      alerts.push({ level:'danger', icon:'🚨', text:`<strong>${t.typ}</strong> — ${t.clientName}<br><span style="font-size:12px;color:var(--text-muted)">Termín byl ${fmt(t.next)} (${Math.abs(t.days)} dní po splatnosti). Nutno okamžitě řešit.</span>` });
    else if (t.days <= 7)
      alerts.push({ level:'danger', icon:'⚠️', text:`<strong>${t.typ}</strong> — ${t.clientName}<br><span style="font-size:12px;color:var(--text-muted)">Zbývá pouze ${t.days} dní do termínu ${fmt(t.next)}.</span>` });
    else if (t.days <= 30)
      alerts.push({ level:'warn',   icon:'🔔', text:`<strong>${t.typ}</strong> — ${t.clientName}<br><span style="font-size:12px;color:var(--text-muted)">Termín ${fmt(t.next)} — zbývá ${t.days} dní.</span>` });
  });
  document.getElementById('notif-list').innerHTML = alerts.length === 0
    ? `<div class="empty-state"><div class="empty-icon">🟢</div><div class="empty-text">Vše v pořádku — žádné urgentní notifikace</div></div>`
    : alerts.map(a => `<div class="notif-banner ${a.level}"><span class="notif-icon">${a.icon}</span><div style="font-size:13px;">${a.text}</div></div>`).join('');
}

// ============================================================
// EXPORT CSV
// ============================================================
function exportCSV() {
  const data = getVisible();
  const header = 'Firma;IČO;Typ úkonu;Kategorie;Poslední realizace;Příští termín;Zbývá dní;Status;Perioda (měs.);Odpovědná osoba\n';
  const rows = data.map(t => {
    const client = CLIENTS.find(c => c.id === t.clientId);
    return [
      t.clientName, client ? client.ico : '', t.typ, t.kategorie,
      fmt(t.posledni), fmt(t.next), t.days,
      t.status === 'po-splatnosti' ? 'Po splatnosti' : t.status === 'blizi' ? 'Blíží se' : 'OK',
      t.perioda, t.odpovedny
    ].join(';');
  }).join('\n');
  const blob = new Blob(['\uFEFF' + header + rows], { type: 'text/csv;charset=utf-8;' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url; a.download = 'BOZP_terminy_toman.csv'; a.click();
  URL.revokeObjectURL(url);
}
</script>
