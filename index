<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ing. Ondřej Toman — BOZP &amp; PO portál</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #1a2744;
    --navy-light: #243460;
    --gold: #c9a44e;
    --gold-light: #e8c97a;
    --cream: #f7f4ef;
    --text: #1a1a1a;
    --text-muted: #5a5a6a;
    --danger: #c0392b;
    --warning: #e67e22;
    --success: #27ae60;
    --info: #2980b9;
    --border: rgba(26,39,68,0.12);
    --radius: 10px;
    --shadow: 0 2px 16px rgba(26,39,68,0.10);
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text);
    min-height: 100vh;
  }

  /* ===== LOGIN ===== */
  #login-screen {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 60%, #2a3d6e 100%);
    padding: 2rem;
  }

  .login-box {
    background: #fff;
    border-radius: 18px;
    padding: 3rem 2.5rem 2.5rem;
    width: 100%;
    max-width: 420px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.25);
    text-align: center;
  }

  .logo-wrap { margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: center; gap: 14px; }
  .logo-text-wrap { text-align: left; }
  .logo-title { font-family: 'Libre Baskerville', serif; font-size: 15px; font-weight: 700; color: var(--navy); letter-spacing: 0.02em; line-height: 1.2; }
  .logo-sub { font-size: 10px; color: var(--gold); letter-spacing: 0.18em; text-transform: uppercase; font-weight: 500; margin-top: 2px; }

  .login-heading { font-family: 'Libre Baskerville', serif; font-size: 22px; color: var(--navy); margin-bottom: 0.25rem; }
  .login-sub { font-size: 13px; color: var(--text-muted); margin-bottom: 2rem; }

  .field-group { text-align: left; margin-bottom: 1rem; }
  .field-group label { font-size: 12px; font-weight: 500; color: var(--text-muted); display: block; margin-bottom: 5px; letter-spacing: 0.06em; text-transform: uppercase; }
  .field-group input {
    width: 100%; padding: 10px 14px; border: 1.5px solid var(--border);
    border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 14px;
    color: var(--text); background: var(--cream); outline: none; transition: border 0.2s;
  }
  .field-group input:focus { border-color: var(--gold); background: #fff; }

  .btn-login {
    width: 100%; padding: 12px; background: var(--navy); color: #fff;
    border: none; border-radius: 8px; font-family: 'DM Sans', sans-serif;
    font-size: 15px; font-weight: 500; cursor: pointer; transition: background 0.2s, transform 0.1s;
    margin-top: 0.5rem;
  }
  .btn-login:hover { background: var(--navy-light); }
  .btn-login:active { transform: scale(0.98); }

  .login-accounts { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); text-align: left; }
  .login-accounts p { font-size: 11px; color: var(--text-muted); margin-bottom: 0.6rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; }
  .account-chip {
    display: inline-block; background: var(--cream); border: 1px solid var(--border);
    border-radius: 20px; padding: 4px 10px; font-size: 12px; color: var(--navy);
    cursor: pointer; margin: 3px 3px 3px 0; transition: background 0.15s;
  }
  .account-chip:hover { background: #e8e4dc; }
  .error-msg { color: var(--danger); font-size: 13px; margin-top: 8px; min-height: 18px; }

  /* ===== APP ===== */
  #app { display: none; min-height: 100vh; }

  .topbar {
    background: var(--navy);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: 58px;
    position: sticky; top: 0; z-index: 100;
    box-shadow: 0 2px 12px rgba(0,0,0,0.18);
  }
  .topbar-logo { display: flex; align-items: center; gap: 12px; }
  .topbar-logo .logo-title { color: #fff; font-size: 13px; }
  .topbar-logo .logo-sub { color: var(--gold-light); }
  .topbar-right { display: flex; align-items: center; gap: 16px; }
  .topbar-user { font-size: 13px; color: rgba(255,255,255,0.75); }
  .topbar-user strong { color: #fff; }
  .btn-logout {
    font-size: 12px; color: rgba(255,255,255,0.6); background: none;
    border: 1px solid rgba(255,255,255,0.2); border-radius: 6px;
    padding: 5px 10px; cursor: pointer; font-family: 'DM Sans', sans-serif;
    transition: all 0.15s;
  }
  .btn-logout:hover { color: #fff; border-color: rgba(255,255,255,0.5); }

  .app-layout { display: flex; min-height: calc(100vh - 58px); }

  .sidebar {
    width: 220px; min-width: 220px; background: #fff;
    border-right: 1px solid var(--border);
    padding: 1.5rem 0;
  }
  .sidebar-section { padding: 0 1rem; margin-bottom: 1.5rem; }
  .sidebar-section-title { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); padding: 0 0.5rem; margin-bottom: 0.5rem; }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; border-radius: 8px; cursor: pointer;
    font-size: 13px; color: var(--text-muted); font-weight: 400;
    transition: background 0.15s, color 0.15s; margin-bottom: 2px;
  }
  .nav-item:hover { background: var(--cream); color: var(--text); }
  .nav-item.active { background: var(--navy); color: #fff; font-weight: 500; }
  .nav-icon { font-size: 15px; width: 20px; text-align: center; }
  .nav-badge {
    margin-left: auto; background: var(--danger); color: #fff;
    font-size: 10px; font-weight: 600; padding: 2px 6px;
    border-radius: 10px; min-width: 18px; text-align: center;
  }
  .nav-badge.warn { background: var(--warning); }

  .main { flex: 1; padding: 2rem; overflow-y: auto; }

  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-family: 'Libre Baskerville', serif; font-size: 24px; color: var(--navy); }
  .page-header p { font-size: 13px; color: var(--text-muted); margin-top: 4px; }

  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 2rem; }
  .stat-card {
    background: #fff; border-radius: var(--radius); border: 1px solid var(--border);
    padding: 1.25rem; transition: box-shadow 0.15s;
  }
  .stat-card:hover { box-shadow: var(--shadow); }
  .stat-label { font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
  .stat-value { font-size: 30px; font-weight: 600; color: var(--navy); line-height: 1; }
  .stat-note { font-size: 12px; color: var(--text-muted); margin-top: 6px; }
  .stat-card.danger .stat-value { color: var(--danger); }
  .stat-card.warn .stat-value { color: var(--warning); }
  .stat-card.ok .stat-value { color: var(--success); }

  .section-title {
    font-family: 'Libre Baskerville', serif; font-size: 16px; color: var(--navy);
    margin-bottom: 1rem; display: flex; align-items: center; justify-content: space-between;
  }
  .section-title .btn-sm {
    font-size: 12px; font-family: 'DM Sans', sans-serif; background: var(--navy);
    color: #fff; border: none; border-radius: 6px; padding: 6px 14px; cursor: pointer;
    font-weight: 500; transition: background 0.15s;
  }
  .section-title .btn-sm:hover { background: var(--navy-light); }

  .table-wrap { background: #fff; border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; margin-bottom: 2rem; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead tr { background: #f0ede8; }
  th { padding: 10px 14px; text-align: left; font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); border-bottom: 1px solid var(--border); }
  td { padding: 12px 14px; border-bottom: 1px solid var(--border); vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #faf8f5; }

  .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; letter-spacing: 0.04em; }
  .badge-danger { background: #fde8e8; color: var(--danger); }
  .badge-warn { background: #fef3e2; color: var(--warning); }
  .badge-ok { background: #e8f8ed; color: var(--success); }
  .badge-info { background: #e8f2fd; color: var(--info); }
  .badge-navy { background: #e8eaf5; color: var(--navy); }
  .badge-gray { background: #f0ede8; color: #5a5a6a; }

  .clients-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 2rem; }
  .client-card {
    background: #fff; border-radius: var(--radius); border: 1px solid var(--border);
    padding: 1.25rem; cursor: pointer; transition: box-shadow 0.15s, border-color 0.15s;
    position: relative;
  }
  .client-card:hover { box-shadow: var(--shadow); border-color: var(--gold); }
  .client-name { font-weight: 600; font-size: 14px; color: var(--navy); margin-bottom: 4px; }
  .client-ico { font-size: 11px; color: var(--text-muted); margin-bottom: 10px; }
  .client-meta { display: flex; gap: 6px; flex-wrap: wrap; }
  .client-alert-dot { position: absolute; top: 12px; right: 12px; width: 10px; height: 10px; border-radius: 50%; }
  .dot-danger { background: var(--danger); }
  .dot-warn { background: var(--warning); }
  .dot-ok { background: var(--success); }

  /* MODAL */
  .modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(26,39,68,0.55); z-index: 500;
    align-items: center; justify-content: center; padding: 1rem;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: #fff; border-radius: 16px; padding: 2rem;
    width: 100%; max-width: 580px; max-height: 85vh; overflow-y: auto;
    box-shadow: 0 16px 64px rgba(0,0,0,0.2);
  }
  .modal-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; }
  .modal-title { font-family: 'Libre Baskerville', serif; font-size: 20px; color: var(--navy); }
  .modal-close { background: none; border: none; font-size: 20px; cursor: pointer; color: var(--text-muted); line-height: 1; padding: 4px; }
  .modal-close:hover { color: var(--text); }
  .modal-section { margin-bottom: 1.25rem; }
  .modal-section-title { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.5rem; padding-bottom: 6px; border-bottom: 1px solid var(--border); }

  .search-bar {
    width: 100%; padding: 10px 14px; border: 1.5px solid var(--border);
    border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 14px;
    background: #fff; outline: none; margin-bottom: 1rem; transition: border 0.2s;
  }
  .search-bar:focus { border-color: var(--gold); }

  .filter-pills { display: flex; gap: 8px; margin-bottom: 1rem; flex-wrap: wrap; }
  .pill {
    padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 500;
    cursor: pointer; border: 1.5px solid var(--border); background: #fff; color: var(--text-muted);
    transition: all 0.15s;
  }
  .pill.active { background: var(--navy); color: #fff; border-color: var(--navy); }
  .pill:hover:not(.active) { background: var(--cream); }

  .notif-banner {
    background: #fff4e5; border: 1px solid #fcd997; border-radius: var(--radius);
    padding: 1rem 1.25rem; margin-bottom: 0.75rem; display: flex; gap: 10px; align-items: flex-start;
  }
  .notif-banner.danger { background: #fde8e8; border-color: #f5b7b7; }
  .notif-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

  .empty-state { text-align: center; padding: 3rem; color: var(--text-muted); }
  .empty-icon { font-size: 40px; margin-bottom: 0.75rem; }
  .empty-text { font-size: 14px; }

  .hidden { display: none !important; }

  .export-card {
    background: #fff; border-radius: var(--radius); border: 1px solid var(--border);
    padding: 2rem; margin-bottom: 1.5rem;
  }
  .export-card h3 { font-family: 'Libre Baskerville', serif; font-size: 16px; color: var(--navy); margin-bottom: 8px; }
  .export-card p { font-size: 13px; color: var(--text-muted); margin-bottom: 1rem; line-height: 1.6; }
  .export-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .code-block {
    background: var(--cream); border: 1px solid var(--border); border-radius: 8px;
    padding: 14px; font-family: monospace; font-size: 12px; color: var(--navy);
    line-height: 1.7;
  }
  .notif-schedule { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 0.5rem; }
  .notif-pill {
    background: var(--cream); border-radius: 8px; padding: 10px 16px;
    font-size: 13px; text-align: center; min-width: 110px; border: 1px solid var(--border);
  }
  .notif-pill-icon { font-size: 18px; margin-bottom: 4px; }
  .notif-pill-label { font-weight: 500; color: var(--navy); font-size: 12px; }
  .notif-pill-sub { font-size: 10px; color: var(--text-muted); margin-top: 2px; }
  .checkbox-list { display: flex; flex-direction: column; gap: 8px; }
  .checkbox-list label { display: flex; align-items: center; gap: 8px; font-size: 13px; cursor: pointer; color: var(--text-muted); }
  .checkbox-list input[type=checkbox] { accent-color: var(--navy); width: 15px; height: 15px; }

  @media (max-width: 900px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .clients-grid { grid-template-columns: repeat(2, 1fr); }
    .export-grid { grid-template-columns: 1fr; }
    .sidebar { width: 180px; min-width: 180px; }
  }
  @media (max-width: 640px) {
    .sidebar { display: none; }
    .clients-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .main { padding: 1rem; }
  }
</style>
</head>
<body>

<!-- ===== LOGIN ===== -->
<div id="login-screen">
  <div class="login-box">
    <div class="logo-wrap">
      <svg width="56" height="56" viewBox="0 0 52 52" xmlns="http://www.w3.org/2000/svg">
        <path d="M26 3L5 12v14c0 12.5 8.9 24.2 21 27.5C38.1 50.2 47 38.5 47 26V12L26 3z" fill="#1a2744" stroke="#c9a44e" stroke-width="1.5"/>
        <path d="M26 9L10 16.5v11.2c0 9.8 7 19 16 21.6 9-2.6 16-11.8 16-21.6V16.5L26 9z" fill="#243460"/>
        <line x1="14" y1="22" x2="38" y2="22" stroke="#c9a44e" stroke-width="0.8" stroke-opacity="0.5"/>
        <text x="26" y="34" text-anchor="middle" font-family="Georgia, serif" font-size="16" font-weight="700" fill="#c9a44e">OT</text>
      </svg>
      <div class="logo-text-wrap">
        <div class="logo-title">Ing. Ondřej Toman</div>
        <div class="logo-sub">BOZP &amp; PO poradenství</div>
      </div>
    </div>
    <h2 class="login-heading">Klientský portál</h2>
    <p class="login-sub">Přihlaste se e-mailem pro přístup k vašim datům</p>
    <div class="field-group">
      <label>E-mail</label>
      <input type="email" id="login-email" placeholder="vas@email.cz" autocomplete="email">
    </div>
    <div class="field-group">
      <label>Heslo</label>
      <input type="password" id="login-password" placeholder="••••••••" autocomplete="current-password">
    </div>
    <div class="error-msg" id="login-error"></div>
    <button class="btn-login" onclick="doLogin()">Přihlásit se</button>
    <div class="login-accounts">
      <p>Ukázkové účty — klikněte pro vyplnění</p>
      <span class="account-chip" onclick="quickLogin('admin@toman-bozp.cz','admin')">🛡 Správce (admin)</span>
      <span class="account-chip" onclick="quickLogin('abc@stavby.cz','klient')">🏗 ABC Stavby</span>
      <span class="account-chip" onclick="quickLogin('kovarna@email.cz','klient')">⚒ Kovárna s.r.o.</span>
      <span class="account-chip" onclick="quickLogin('logistika@firma.cz','klient')">🚛 LogFirma a.s.</span>
    </div>
  </div>
</div>

<!-- ===== APLIKACE ===== -->
<div id="app">
  <!-- TOP BAR -->
  <div class="topbar">
    <div class="topbar-logo">
      <svg width="34" height="34" viewBox="0 0 52 52" xmlns="http://www.w3.org/2000/svg">
        <path d="M26 3L5 12v14c0 12.5 8.9 24.2 21 27.5C38.1 50.2 47 38.5 47 26V12L26 3z" fill="rgba(255,255,255,0.15)" stroke="#c9a44e" stroke-width="1.5"/>
        <path d="M26 9L10 16.5v11.2c0 9.8 7 19 16 21.6 9-2.6 16-11.8 16-21.6V16.5L26 9z" fill="rgba(255,255,255,0.08)"/>
        <text x="26" y="34" text-anchor="middle" font-family="Georgia, serif" font-size="16" font-weight="700" fill="#c9a44e">OT</text>
      </svg>
      <div class="logo-text-wrap">
        <div class="logo-title" style="font-size:12px;">Ing. Ondřej Toman</div>
        <div class="logo-sub" style="font-size:9px;">BOZP &amp; PO</div>
      </div>
    </div>
    <div class="topbar-right">
      <div class="topbar-user">Přihlášen: <strong id="user-name-display">—</strong></div>
      <button class="btn-logout" onclick="doLogout()">Odhlásit se</button>
    </div>
  </div>

  <div class="app-layout">
    <!-- SIDEBAR -->
    <nav class="sidebar" id="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-section-title">Navigace</div>
        <div class="nav-item active" id="nav-dashboard" onclick="showPage('dashboard')">
          <span class="nav-icon">📊</span> Dashboard
        </div>
        <div class="nav-item" id="nav-terminy" onclick="showPage('terminy')">
          <span class="nav-icon">📅</span> Termíny
          <span class="nav-badge" id="nav-badge-terminy">0</span>
        </div>
        <div class="nav-item" id="nav-klienti" onclick="showPage('klienti')">
          <span class="nav-icon">🏢</span> Klienti
        </div>
        <div class="nav-item" id="nav-notifikace" onclick="showPage('notifikace')">
          <span class="nav-icon">🔔</span> Notifikace
          <span class="nav-badge warn" id="nav-badge-notif">0</span>
        </div>
      </div>
      <div class="sidebar-section" id="sidebar-admin-section">
        <div class="sidebar-section-title">Správa</div>
        <div class="nav-item" id="nav-export" onclick="showPage('export')">
          <span class="nav-icon">📥</span> Export / Excel
        </div>
      </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="main">

      <!-- DASHBOARD -->
      <div id="page-dashboard">
        <div class="page-header">
          <h1 id="dashboard-title">Přehled</h1>
          <p id="dashboard-subtitle">Aktuální stav BOZP a PO</p>
        </div>
        <div id="alert-banners"></div>
        <div class="stats-grid" id="stats-grid"></div>
        <div class="section-title">
          Nejbližší termíny
          <span id="terminy-count" style="font-family:'DM Sans';font-size:13px;color:var(--text-muted);font-weight:400;"></span>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr>
              <th>Typ úkonu</th><th>Firma</th><th>Termín</th><th>Zbývá dní</th><th>Status</th><th>Odpovědná osoba</th>
            </tr></thead>
            <tbody id="terminy-tbody"></tbody>
          </table>
        </div>
      </div>

      <!-- TERMÍNY -->
      <div id="page-terminy" class="hidden">
        <div class="page-header">
          <h1>Všechny termíny</h1>
          <p>Přehled školení, revizí a kontrol BOZP/PO</p>
        </div>
        <input class="search-bar" id="terminy-search" placeholder="Hledat termín, firmu, typ..." oninput="filterTerminy()">
        <div class="filter-pills">
          <span class="pill active" data-filter="vse" onclick="setFilter(this,'vse')">Vše</span>
          <span class="pill" data-filter="po-splatnosti" onclick="setFilter(this,'po-splatnosti')">🔴 Po splatnosti</span>
          <span class="pill" data-filter="blizi" onclick="setFilter(this,'blizi')">🟡 Do 30 dní</span>
          <span class="pill" data-filter="ok" onclick="setFilter(this,'ok')">🟢 V pořádku</span>
          <span class="pill" data-filter="skoleni" onclick="setFilter(this,'skoleni')">Školení</span>
          <span class="pill" data-filter="revize" onclick="setFilter(this,'revize')">Revize</span>
          <span class="pill" data-filter="kontrola" onclick="setFilter(this,'kontrola')">Kontrola</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr>
              <th>Typ</th><th>Kategorie</th><th>Firma</th><th>Poslední</th><th>Příští termín</th><th>Zbývá</th><th>Status</th><th>Perioda</th>
            </tr></thead>
            <tbody id="all-terminy-tbody"></tbody>
          </table>
        </div>
      </div>

      <!-- KLIENTI -->
      <div id="page-klienti" class="hidden">
        <div class="page-header">
          <h1>Klientské firmy</h1>
          <p>Přehled všech spravovaných firem</p>
        </div>
